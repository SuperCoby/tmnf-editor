    private async Task ExportChallengeGbx()
    {
        if (_challengeBytes == null) return;

        var newBlocks = new List<(string clipType, string clipName, string trackName, GBX.NET.Engines.Game.CGameCtnMediaBlockTriangles3D block)>();

        foreach (var entry in _tri3dEntries)
        {
            bool isCustom = _customClips.Contains($"{entry.ClipType}|{entry.ClipName}");

            if (entry.IsImported)
            {
                var data = await JS.InvokeAsync<ImportExportData?>("TMNFeditorScene.getImportExportDataByIndex", entry.ImportIndex);
                if (data == null || string.IsNullOrEmpty(data.ObjText)) continue;

                var anim = GetOrCreateAnim(entry.ImportIndex);

                var transKfs = anim.Trans.Select(k => new ClipGbxExporter.AnimKf(k.Time, k.EndTime, k.X, k.Y, k.Z)).ToList();
                var scaleKfs = anim.Scale.Select(k => new ClipGbxExporter.AnimKf(k.Time, k.EndTime, k.X, k.Y, k.Z)).ToList();
                var rotKfs = anim.Rot.Select(k => new ClipGbxExporter.AnimKf(k.Time, k.EndTime,
                    k.X * Math.PI / 180.0, k.Y * Math.PI / 180.0, k.Z * Math.PI / 180.0, (int)k.Steps)).ToList();

                bool hasAnim = transKfs.Any(k => k.X != 0 || k.Y != 0 || k.Z != 0)
                            || scaleKfs.Any(k => k.X != 1 || k.Y != 1 || k.Z != 1)
                            || rotKfs.Any(k => k.X != 0 || k.Y != 0 || k.Z != 0);

                var mats = await JS.InvokeAsync<ImportMatDto[]>("TMNFeditorScene.getImportMaterialsByIndex", entry.ImportIndex);
                Dictionary<string, string>? matOverrides = null;
                if (mats != null && mats.Length > 0)
                {
                    matOverrides = new();
                    foreach (var mat in mats)
                        if (!string.IsNullOrEmpty(mat.Name) && mat.Name != "(sans nom)")
                            matOverrides[mat.Name] = mat.Hex;
                }

                var rotOrigin = new GBX.NET.Vec3((float)anim.OriginX, (float)anim.OriginY, (float)anim.OriginZ);
                var tri3dBlock = ClipGbxExporter.BuildObjTri3DBlock(
                    data.ObjText, data.MtlText,
                    data.PosX, data.PosY, data.PosZ,
                    hasAnim ? transKfs : null,
                    hasAnim ? scaleKfs : null,
                    hasAnim ? rotKfs : null,
                    matOverrides, (float)anim.Shading,
                    rotationOrigin: rotOrigin);

                newBlocks.Add((entry.ClipType, entry.ClipName, entry.Name, tri3dBlock));
            }
            else if (entry.HasMesh && isCustom && entry.MeshIndex >= 0 && entry.MeshIndex < _tri3dBlocks.Count)
            {
                var block = _tri3dBlocks[entry.MeshIndex];
                var tri3dBlock = ClipGbxExporter.BuildAnimatedTri3DBlock(block, null, null, null);
                newBlocks.Add((entry.ClipType, entry.ClipName, entry.Name, tri3dBlock));
            }
        }

        var result = ClipGbxExporter.ExportChallengeBytes(_challengeBytes, newBlocks);
        if (result.Length == 0) return;

        var fileName = _challengeFileName ?? "Exported.Challenge.Gbx";
        await JS.InvokeVoidAsync("TMNFeditorScene.downloadFileBytes", fileName, Convert.ToBase64String(result));
    }

