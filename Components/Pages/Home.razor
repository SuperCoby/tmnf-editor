@page "/"
@implements IDisposable
@inject FileSystemService FS
@inject PakService PakSvc
@inject HttpClient Http
@inject IJSRuntime JS

<div id="app-header">
    <div id="header-left">
        <button class="hdr-btn hdr-btn-folder" @onclick="SelectGameFolder">📂 Sélectionner le dossier du jeu</button>
        <div class="hdr-sep"></div>
        <button class="hdr-btn hdr-btn-map" @onclick="LoadChallenge">🗺️ Charger une carte</button>
        <button class="hdr-btn hdr-btn-clear" title="Effacer la carte" @onclick="ClearMap">✖</button>
        @if (mapIsLoading)
        {
            <div class="header-progress">
                <div class="header-progress-bar" style="width:@(mapProgress)%"></div>
            </div>
            <span style="font-size:10px;color:#5dda80">@mapStatus</span>
        }
        else if (!string.IsNullOrEmpty(mapStatus))
        {
            <span class="stats">@mapStatus</span>
        }
    </div>
    <div id="header-nav">
        <button class="header-nav-btn @(showBlockPanel   ? "active" : "")" @onclick="ToggleBlockPanel">Block</button>
        <button class="header-nav-btn @(showTriangles3D  ? "active" : "")" @onclick="ToggleTriangles3D">Triangles3D</button>
        <button class="header-nav-btn @(showTriangles2D  ? "active" : "")" @onclick="ToggleTriangles2D">Triangles2D</button>
    </div>
</div>

<div id="block-panel" class="@(showBlockPanel ? "open" : "")">
    <div id="block-panel-header">
        <select id="pak-selector" @onchange="OnPakChanged" disabled="@(pakNames.Count == 0)">
            @if (pakNames.Count == 0)
            {
                <option value="">Sélectionnez un dossier de jeu…</option>
            }
            else
            {
                @foreach (var pak in pakNames)
                {
                    <option value="@pak">@pak</option>
                }
            }
        </select>
        <input type="text" id="search" placeholder="Rechercher un bloc…" @oninput="OnSearch" />
        <div class="stats">@statsText</div>
    </div>
    <div id="model-list">
        @if (isLoadingPak)
        {
            <div class="loading-msg"><span class="loading">⏳ Ouverture de @currentPak</span></div>
        }
        else
        {
            @for (int i = 0; i < filteredSolids.Count; i++)
            {
                var solid = filteredSolids[i];
                var isActive = solid.OriginalIndex == activeModelIndex;
                <div class="model-item @(isActive ? "active" : "")"
                     @onclick="() => LoadModel(solid.OriginalIndex)">
                    [@(solid.OriginalIndex + 1)] @solid.DisplayName
                </div>
            }
        }
    </div>
</div>

<div id="triangles3d-panel" class="@(showTriangles3D ? "open" : "")">
    <div class="side-section">
        <div class="side-section-header import-header">
            <span>Import 3D Model</span>
            @if (_importTabCount > 0)
            {
                <button class="import-icon-btn" style="margin-left:auto;margin-right:4px;color:#5d8a5d;border-color:#2a442a"
                        @onclick="SendImportToMainScene" title="Envoyer vers le rendu 3D">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </button>
            }
            <button class="import-icon-btn" @onclick="TriggerImportFile" title="Importer un .obj">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
            </button>
            <input type="file" id="import-file-input" accept=".obj,.mtl" multiple style="display:none">
        </div>
        <div class="side-section-content import-section-content" id="import-drop-zone">
            @if (_importTabCount > 0)
            {
                <div class="import-tab-bar">
                    @for (int i = 0; i < _importTabCount; i++)
                    {
                        int idx = i;
                        <button class="import-tab-btn @(_activeImportTab == idx ? "active" : "")"
                                @onclick="() => SwitchImportTab(idx)">@(idx + 1)</button>
                    }
                </div>
            }
            <canvas id="import-preview-canvas"></canvas>
            <div class="import-drop-hint" id="import-drop-hint" style="@(_importTabCount > 0 ? "display:none" : "")">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3a3a55" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                    <polyline points="17 8 12 3 7 8"/>
                    <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <div>Déposez un .obj ici</div>
                <div class="drop-sub">.mtl optionnel</div>
            </div>
        </div>
    </div>
    <div class="side-section-divider"></div>
    <div class="side-section">
        <div class="side-section-header">Animation</div>
        <div class="side-section-content" style="display:flex;flex-direction:column">
            <div class="tab-bar">
                @foreach (var tab in _t3dAnimTabs)
                {
                    <button class="tab-btn @(t3dAnimTab == tab ? "active" : "")"
                            @onclick="() => SelectAnimTab(tab)">@tab</button>
                }
            </div>
            <div class="tab-content">
                @if (t3dAnimTab == "Triangles3D")
                {
                        var clips = GetClipsForSelectedType();
                        <div class="tri3d-type-bar">
                            @foreach (var ct in _allClipTypes)
                            {
                                var t = ct;
                                int count = _tri3dEntries.Count(e => e.ClipType == t);
                                <button class="tri3d-type-btn @(_selectedClipType == t ? "active" : "")"
                                        @onclick="() => SelectClipType(t)">@t <span class="tri3d-type-count">@count</span></button>
                            }
                            <div style="flex:1"></div>
                            <button class="tri3d-vis-btn" @onclick="() => SetAllTri3DVisible(true)" title="Tout afficher">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                            <button class="tri3d-vis-btn" @onclick="() => SetAllTri3DVisible(false)" title="Tout cacher">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            </button>
                        </div>
                        <div class="tri3d-split">
                            @if (HasClipsPanel(_selectedClipType))
                            {
                                <div class="tri3d-clips-panel">
                                    <div class="tri3d-panel-header">
                                        <span>Clips</span>
                                        <button class="tri3d-pm-btn" @onclick="AddClip" title="Ajouter un clip">+</button>
                                        <button class="tri3d-pm-btn" @onclick="RemoveSelectedClip" title="Supprimer le clip"
                                                disabled="@(clips.Count == 0)">-</button>
                                    </div>
                                    @for (int ci = 0; ci < clips.Count; ci++)
                                    {
                                        var idx = ci;
                                        var clip = clips[ci];
                                        <div class="tri3d-clip-row @(_selectedClipIdx == idx ? "active" : "")" @onclick="() => { _selectedClipIdx = idx; }">
                                            <span class="tri3d-clip-label">@(ParseTmColors(clip.ClipName))</span>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="tri3d-tracks-panel">
                                <div class="tri3d-panel-header">
                                    <span>Tracks</span>
                                    <button class="tri3d-pm-btn" @onclick="AddTrack" title="Ajouter un track">+</button>
                                    <button class="tri3d-pm-btn" @onclick="RemoveSelectedTrack" title="Supprimer le track"
                                            disabled="@(_selectedTri3DTrack == null || _selectedTri3DTrack.ClipType != _selectedClipType)">-</button>
                                </div>
                                @foreach (var entry in GetSelectedClipTracks())
                                {
                                    var e = entry;
                                    <div class="tri3d-track-row @(_selectedTri3DTrack == e ? "selected" : "")" @onclick="() => SelectTri3DTrack(e)">
                                        @if (e.HasMesh || e.IsImported)
                                        {
                                            <button class="tri3d-eye @(!e.Visible ? "hidden" : "")" @onclick="() => ToggleTri3DVisible(e)" title="@(e.Visible ? "Cacher" : "Afficher")">
                                                @if (e.Visible)
                                                {
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                                    </svg>
                                                }
                                                else
                                                {
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                                        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                                        <line x1="1" y1="1" x2="23" y2="23"/>
                                                    </svg>
                                                }
                                            </button>
                                        }
                                        <span class="tri3d-track-name">@(ParseTmColors(e.Name))</span>
                                        @if (!e.HasMesh && !e.IsImported)
                                        {
                                            <button class="tri3d-import-btn" @onclick="() => AssignImportToTrack(e)"
                                                    disabled="@(_importTabCount == 0)"
                                                    title="Importer le modèle actif dans ce track">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                                    <polyline points="17 8 12 3 7 8"/>
                                                    <line x1="12" y1="3" x2="12" y2="15"/>
                                                </svg>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                }
                else if (t3dAnimTab == "Translation")
                {
                    @if (!_hasActiveObject)
                    {
                        <div class="pos-empty">@(_importTabCount == 0 ? "Aucun modèle importé" : "Modèle non transféré vers le rendu")</div>
                    }
                    else
                    {
                    <div class="anim-table-wrap">
                        <table class="anim-table">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>EndTime</th>
                                    <th>X</th>
                                    <th>Y</th>
                                    <th>Z</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _animKeyframes.Count; i++)
                                {
                                    int row = i;
                                    var kf = _animKeyframes[row];
                                    <tr>
                                        <td><input class="anim-input" type="number" step="0.1"
                                                   value="@kf.Time.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                                   @onchange="e => OnAnimChange(e, row, 't')" /></td>
                                        <td><input class="anim-input" type="number" step="0.1"
                                                   value="@kf.EndTime.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                                   @onchange="e => OnAnimChange(e, row, 'e')" /></td>
                                        <td><input class="anim-input ax-x-bg" type="number" step="0.001"
                                                   value="@kf.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                                   @onchange="e => OnAnimChange(e, row, 'x')" /></td>
                                        <td><input class="anim-input ax-y-bg" type="number" step="0.001"
                                                   value="@kf.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                                   @onchange="e => OnAnimChange(e, row, 'y')" /></td>
                                        <td><input class="anim-input ax-z-bg" type="number" step="0.001"
                                                   value="@kf.Z.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                                   @onchange="e => OnAnimChange(e, row, 'z')" /></td>
                                        <td>
                                            <div class="anim-row-actions">
                                                <button type="button" class="anim-row-btn anim-row-btn-add" @onclick="() => AddAnimKeyframe(row)" @onclick:stopPropagation title="Ajouter">+</button>
                                                @if (row == 0)
                                                {
                                                    <button class="anim-row-btn anim-row-btn-reset" @onclick="ResetAnimKeyframes" title="Reset">R</button>
                                                }
                                                @if (row > 0)
                                                {
                                                    <button class="anim-row-btn anim-row-btn-del" @onclick="() => RemoveAnimKeyframe(row)" title="Supprimer">-</button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    }
                }
                else if (t3dAnimTab == "Scaling")
                {
                    @if (!_hasActiveObject)
                    {
                        <div class="pos-empty">@(_importTabCount == 0 ? "Aucun modèle importé" : "Modèle non transféré vers le rendu")</div>
                    }
                    else
                    {
                    <div class="anim-table-wrap">
                        <table class="anim-table">
                            <thead><tr><th>Time</th><th>EndTime</th><th>X</th><th>Y</th><th>Z</th><th></th></tr></thead>
                            <tbody>
                                @for (int i = 0; i < _scalingKeyframes.Count; i++)
                                {
                                    int row = i;
                                    var kf = _scalingKeyframes[row];
                                    <tr>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.Time.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnScalingChange(e, row, 't')" /></td>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.EndTime.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnScalingChange(e, row, 'e')" /></td>
                                        <td><input class="anim-input ax-x-bg" type="number" step="0.1" value="@kf.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnScalingChange(e, row, 'x')" /></td>
                                        <td><input class="anim-input ax-y-bg" type="number" step="0.1" value="@kf.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnScalingChange(e, row, 'y')" /></td>
                                        <td><input class="anim-input ax-z-bg" type="number" step="0.1" value="@kf.Z.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnScalingChange(e, row, 'z')" /></td>
                                        <td><div class="anim-row-actions">
                                            <button type="button" class="anim-row-btn anim-row-btn-add" @onclick="() => AddScalingKeyframe(row)" @onclick:stopPropagation title="Ajouter">+</button>
                                            @if (row == 0) { <button class="anim-row-btn anim-row-btn-reset" @onclick="ResetScalingKeyframes" title="Reset">R</button> }
                                            @if (row > 0) { <button class="anim-row-btn anim-row-btn-del" @onclick="() => RemoveScalingKeyframe(row)" title="Supprimer">-</button> }
                                        </div></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    }
                }
                else if (t3dAnimTab == "Rotation")
                {
                    @if (!_hasActiveObject)
                    {
                        <div class="pos-empty">@(_importTabCount == 0 ? "Aucun modèle importé" : "Modèle non transféré vers le rendu")</div>
                    }
                    else
                    {
                    <div class="anim-table-wrap">
                        <table class="anim-table">
                            <thead><tr><th>Time</th><th>EndTime</th><th>X</th><th>Y</th><th>Z</th><th>Steps</th><th></th></tr></thead>
                            <tbody>
                                @for (int i = 0; i < _rotationKeyframes.Count; i++)
                                {
                                    int row = i;
                                    var kf = _rotationKeyframes[row];
                                    <tr>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.Time.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnRotationChange(e, row, 't')" /></td>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.EndTime.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnRotationChange(e, row, 'e')" /></td>
                                        <td><input class="anim-input ax-x-bg" type="number" step="0.1" value="@kf.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnRotationChange(e, row, 'x')" /></td>
                                        <td><input class="anim-input ax-y-bg" type="number" step="0.1" value="@kf.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnRotationChange(e, row, 'y')" /></td>
                                        <td><input class="anim-input ax-z-bg" type="number" step="0.1" value="@kf.Z.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnRotationChange(e, row, 'z')" /></td>
                                        <td><input class="anim-input" type="number" step="1" value="@kf.Steps.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnRotationChange(e, row, 's')" /></td>
                                        <td><div class="anim-row-actions">
                                            <button type="button" class="anim-row-btn anim-row-btn-add" @onclick="() => AddRotationKeyframe(row)" @onclick:stopPropagation title="Ajouter">+</button>
                                            @if (row == 0) { <button class="anim-row-btn anim-row-btn-reset" @onclick="ResetRotationKeyframes" title="Reset">R</button> }
                                            @if (row > 0) { <button class="anim-row-btn anim-row-btn-del" @onclick="() => RemoveRotationKeyframe(row)" title="Supprimer">-</button> }
                                        </div></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    }
                }
                else if (t3dAnimTab == "Orbit")
                {
                    @if (!_hasActiveObject)
                    {
                        <div class="pos-empty">@(_importTabCount == 0 ? "Aucun modèle importé" : "Modèle non transféré vers le rendu")</div>
                    }
                    else
                    {
                    <div class="anim-table-wrap">
                        <table class="anim-table">
                            <thead><tr><th>Time</th><th>EndTime</th><th>Radius</th><th>Steps</th><th>Degrees(°)</th><th></th></tr></thead>
                            <tbody>
                                @for (int i = 0; i < _orbitKeyframes.Count; i++)
                                {
                                    int row = i;
                                    var kf = _orbitKeyframes[row];
                                    <tr>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.Time.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnOrbitChange(e, row, 't')" /></td>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.EndTime.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnOrbitChange(e, row, 'e')" /></td>
                                        <td><input class="anim-input" type="number" step="0.1" value="@kf.Radius.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnOrbitChange(e, row, 'r')" /></td>
                                        <td><input class="anim-input" type="number" step="1" value="@kf.Steps.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnOrbitChange(e, row, 's')" /></td>
                                        <td><input class="anim-input" type="number" step="1" value="@kf.Degrees.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" @onchange="e => OnOrbitChange(e, row, 'd')" /></td>
                                        <td><div class="anim-row-actions">
                                            <button type="button" class="anim-row-btn anim-row-btn-add" @onclick="() => AddOrbitKeyframe(row)" @onclick:stopPropagation title="Ajouter">+</button>
                                            @if (row == 0) { <button class="anim-row-btn anim-row-btn-reset" @onclick="ResetOrbitKeyframes" title="Reset">R</button> }
                                            @if (row > 0) { <button class="anim-row-btn anim-row-btn-del" @onclick="() => RemoveOrbitKeyframe(row)" title="Supprimer">-</button> }
                                        </div></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    }
                }
                else if (t3dAnimTab == "Shading Intensity")
                {
                    @if (!_hasActiveObject)
                    {
                        <div class="pos-empty">@(_importTabCount == 0 ? "Aucun modèle importé" : "Modèle non transféré vers le rendu")</div>
                    }
                    else
                    {
                        <div class="shading-wrap">
                            <input type="range" class="shading-slider" min="0" max="1" step="0.01"
                                   value="@_shadingIntensity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                   @oninput="OnShadingSlider" />
                            <input type="number" class="shading-value" min="0" max="1" step="0.01"
                                   value="@_shadingIntensity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                   @onchange="OnShadingInput" />
                        </div>
                        <button class="origin-center-btn" @onclick="ResetShading">Reset</button>
                    }
                }
                else if (t3dAnimTab == "Material")
                {
                    @if (_importMaterials.Count == 0)
                    {
                        <div class="pos-empty">Aucun matériau</div>
                    }
                    else
                    {
                        <div class="mat-list">
                            @foreach (var mat in _importMaterials)
                            {
                                var m = mat;
                                <div class="mat-item">
                                    <div class="mat-name" title="@m.Name">@m.Name</div>
                                    <div class="mat-color-row">
                                        <input type="color" class="mat-color-picker"
                                               value="@m.Hex"
                                               @onchange="async e => await SetMaterialColor(m, e.Value?.ToString() ?? m.Hex)" />
                                        <span class="mat-hex">@m.Hex</span>
                                    </div>
                                </div>
                            }
                        </div>
                        <button class="origin-center-btn" @onclick="ResetMaterials">Reset</button>
                    }
                }
                else if (t3dAnimTab == "Origin")
                {
                    @if (!_hasActiveObject)
                    {
                        <div class="pos-empty">@(_importTabCount == 0 ? "Aucun modèle importé" : "Modèle non transféré vers le rendu")</div>
                    }
                    else
                    {
                        <div class="pos-grid">
                            <span class="pos-axis ax-x">X</span>
                            <input class="pos-input" type="number" step="1"
                                   value="@_importOriginX.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                   @onchange="e => OnOriginChange(e, 'x')" />
                            <span class="pos-axis ax-y">Y</span>
                            <input class="pos-input" type="number" step="1"
                                   value="@_importOriginY.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                   @onchange="e => OnOriginChange(e, 'y')" />
                            <span class="pos-axis ax-z">Z</span>
                            <input class="pos-input" type="number" step="1"
                                   value="@_importOriginZ.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                   @onchange="e => OnOriginChange(e, 'z')" />
                        </div>
