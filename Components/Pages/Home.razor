    protected override async Task OnInitializedAsync()
    {
        try
        {
            var content = await Http.GetStringAsync("FileHashes_TMUF.txt");
            PakSvc.LoadFileHashes(content);
        }
        catch { }

        // Charger les mappings bloc→variant→solid et tailles de blocs pour la résolution des cartes
        foreach (var pakName in PakService.PaksWithMappings)
        {
            try
            {
                var json = await Http.GetStringAsync($"mappings/{pakName}_block_variants.json");
                PakSvc.LoadBlockVariants(pakName, json);
            }
            catch { }
            try
            {
                var json = await Http.GetStringAsync($"mappings/{pakName}_block_coord_sizes.json");
                PakSvc.LoadBlockCoordSizes(pakName, json);
            }
            catch { }
        }
    }

