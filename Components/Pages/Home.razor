    private List<Tri3DEntry> _tri3dEntries = new();
    private List<Tri3DBlock> _tri3dBlocks = new();
    private HashSet<string> _customClips = new();
    private static readonly string[] _allClipTypes = ["Intro", "In Game", "End Race", "Global"];
    private string _selectedClipType = "In Game";
    private int _selectedClipIdx = 0;

    private record ClipInfo(string ClipType, string ClipName, string Key);

    private List<string> GetDistinctClipTypes() =>
        _tri3dEntries.Select(e => e.ClipType).Distinct().ToList();

    private List<ClipInfo> GetClipsForSelectedType()
    {
        var fromEntries = _tri3dEntries
            .Where(e => e.ClipType == _selectedClipType)
            .Select(e => e.ClipName)
            .Distinct();
        var fromCustom = _customClips
            .Where(k => k.StartsWith(_selectedClipType + "|"))
            .Select(k => k.Substring(_selectedClipType.Length + 1));
        return fromEntries.Union(fromCustom)
            .Select(n => new ClipInfo(_selectedClipType, n, $"{_selectedClipType}|{n}"))
            .ToList();
    }

    private static bool HasClipsPanel(string type) => type is "In Game" or "End Race";

    private void SelectClipType(string type)
    {
        _selectedClipType = type;
        _selectedClipIdx = 0;
    }

    private List<Tri3DEntry> GetSelectedClipTracks()
    {
        if (!HasClipsPanel(_selectedClipType))
            return _tri3dEntries.Where(e => e.ClipType == _selectedClipType).ToList();

        var clips = GetClipsForSelectedType();
        if (_selectedClipIdx < 0 || _selectedClipIdx >= clips.Count) return new();
        var sel = clips[_selectedClipIdx];
        return _tri3dEntries.Where(e => e.ClipType == sel.ClipType && e.ClipName == sel.ClipName).ToList();
    }

    private void AddClip()
    {
        var clips = GetClipsForSelectedType();
        int n = 1;
        string name;
        do { name = $"New Clip {n++}"; }
        while (clips.Any(c => c.ClipName == name));

        _customClips.Add($"{_selectedClipType}|{name}");
        _selectedClipIdx = GetClipsForSelectedType().Count - 1;
    }

    private void RemoveSelectedClip()
    {
        var clips = GetClipsForSelectedType();
        if (_selectedClipIdx < 0 || _selectedClipIdx >= clips.Count) return;
        var sel = clips[_selectedClipIdx];
        _tri3dEntries.RemoveAll(e => e.ClipType == sel.ClipType && e.ClipName == sel.ClipName);
        _customClips.Remove($"{sel.ClipType}|{sel.ClipName}");
        if (_selectedTri3DTrack?.ClipName == sel.ClipName) _selectedTri3DTrack = null;
        _selectedClipIdx = Math.Clamp(_selectedClipIdx, 0, Math.Max(0, GetClipsForSelectedType().Count - 1));
