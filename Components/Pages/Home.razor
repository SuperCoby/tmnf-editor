    // ── Animation keyframes ─────────────────────────────────────────────────
    private class AnimKeyframe
    {
        public double Time    { get; set; }
        public double EndTime { get; set; }
        public double X       { get; set; }
        public double Y       { get; set; }
        public double Z       { get; set; }
    }

    private class RotationKeyframe
    {
        public double Time    { get; set; }
        public double EndTime { get; set; }
        public double X       { get; set; }
        public double Y       { get; set; }
        public double Z       { get; set; }
        public double Steps   { get; set; } = 10;
    }

    private class OrbitKeyframe
    {
        public double Time    { get; set; }
        public double EndTime { get; set; }
        public double Radius  { get; set; } = 2;
        public double Steps   { get; set; } = 60;
        public double Degrees { get; set; } = 360;
    }

    private List<AnimKeyframe> _animKeyframes = new() { new() { Time = 0, EndTime = 3 } };
    private List<AnimKeyframe> _scalingKeyframes = new() { new() { Time = 0, EndTime = 3, X = 1, Y = 1, Z = 1 } };
    private List<RotationKeyframe> _rotationKeyframes = new() { new() { Time = 0, EndTime = 3 } };
    private List<OrbitKeyframe> _orbitKeyframes = new() { new() { Time = 0, EndTime = 3 } };

    private static void KfChange(List<AnimKeyframe> list, ChangeEventArgs e, int row, char field)
    {
        if (!double.TryParse(e.Value?.ToString(),
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var v)) return;
        var kf = list[row];
        switch (field)
        {
            case 't': kf.Time    = v; break;
            case 'e': kf.EndTime = v; break;
            case 'x': kf.X      = v; break;
            case 'y': kf.Y      = v; break;
            case 'z': kf.Z      = v; break;
        }
    }

    private static void KfAdd(List<AnimKeyframe> list, int afterRow)
    {
        var prev = list[afterRow];
        list.Insert(afterRow + 1, new AnimKeyframe { Time = prev.EndTime, EndTime = prev.EndTime + 3 });
    }

    private static void KfRemove(List<AnimKeyframe> list, int row) { if (list.Count > 1) list.RemoveAt(row); }

    private void OnAnimChange(ChangeEventArgs e, int row, char field) => KfChange(_animKeyframes, e, row, field);
    private void AddAnimKeyframe(int afterRow) => KfAdd(_animKeyframes, afterRow);
    private void RemoveAnimKeyframe(int row) => KfRemove(_animKeyframes, row);
    private void ResetAnimKeyframes() { _animKeyframes = new() { new() { Time = 0, EndTime = 3 } }; }

    private bool _playbackRepeat = false;

    private object[] BuildPlaybackKeyframes()
    {
        return _animKeyframes.Select(kf => (object)new
        {
            time = kf.Time,
            endTime = kf.EndTime,
            x = kf.X,
            y = kf.Y,
            z = kf.Z
        }).ToArray();
    }

    private object[] BuildScalingKeyframes()
    {
        return _scalingKeyframes.Select(kf => (object)new
        {
            time = kf.Time,
            endTime = kf.EndTime,
            x = kf.X,
            y = kf.Y,
            z = kf.Z
        }).ToArray();
    }

    private object[] BuildRotationKeyframes()
    {
        return _rotationKeyframes.Select(kf => (object)new
        {
            time = kf.Time,
            endTime = kf.EndTime,
            x = kf.X * Math.PI / 180.0,
            y = kf.Y * Math.PI / 180.0,
            z = kf.Z * Math.PI / 180.0
        }).ToArray();
    }

    private double GetTotalEndTime()
    {
        double t = 0;
        if (_animKeyframes.Count > 0) t = Math.Max(t, _animKeyframes[^1].EndTime);
        if (_scalingKeyframes.Count > 0) t = Math.Max(t, _scalingKeyframes[^1].EndTime);
        if (_rotationKeyframes.Count > 0) t = Math.Max(t, _rotationKeyframes[^1].EndTime);
        return t;
    }

    private async Task PlaybackPlay()
    {
        var transKf = BuildPlaybackKeyframes();
        var scaleKf = BuildScalingKeyframes();
        var rotKf = BuildRotationKeyframes();
        await JS.InvokeVoidAsync("TMNFeditorScene.playbackStart", transKf, scaleKf, rotKf, _playbackRepeat);
    }

