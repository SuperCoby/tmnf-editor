@page "/"
@implements IDisposable

<HelpPopup />
<SettingsPopup />

<HeaderBar OnSelectGameFolder="SelectGameFolder"
           OnLoadChallenge="LoadChallenge"
           OnClearMap="ClearMap" />

<BlockPanel OnPakChanged="OnPakChanged"
            OnSearch="OnSearch"
            OnLoadModel="LoadModel" />

<TrianglesPanel DotNetRef="_dotNetRef" />

<div id="three-container" @ref="threeContainer">
    <PlaybackBar />
    <div class="select-mode-btns">
        <button class="select-mode-btn @(State.BlockSelectMode ? "" : "active")"
                @onclick="SetMeshMode" title="Mode Mesh — Material + Texture">
            Mesh
        </button>
        <button class="select-mode-btn @(State.BlockSelectMode ? "active" : "")"
                @onclick="SetBlockMode" title="Mode Block — Nom du block">
            Block
        </button>
    </div>
</div>

<Toolbar3D />
