@implements IDisposable
@inject AppState State

@if (State.ShowTriangles3D)
{
    <div class="t3d-toolbar">
        <button class="t3d-tool @(State.T3dTool == "translate" ? "active" : "")"
                @onclick='() => SetTool("translate")' title="@State.T("Déplacer")">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="5 9 2 12 5 15"/><polyline points="9 5 12 2 15 5"/>
                <polyline points="15 19 12 22 9 19"/><polyline points="19 9 22 12 19 15"/>
                <line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/>
            </svg>
        </button>
        <button class="t3d-tool @(State.T3dTool == "rotate" ? "active" : "")"
                @onclick='() => SetTool("rotate")' title="Rotation">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.5 2v6h-6"/><path d="M21.34 15.57a10 10 0 1 1-.57-8.38"/>
            </svg>
        </button>
        <button class="t3d-tool @(State.T3dTool == "scale" ? "active" : "")"
                @onclick='() => SetTool("scale")' title="Scale">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
                <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
            </svg>
        </button>
        <div class="t3d-sep"></div>
        <button class="t3d-tool" @onclick="State.MirrorImport" title="Mirror X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="3" x2="12" y2="21"/><polyline points="8 7 3 12 8 17"/>
                <polyline points="16 7 21 12 16 17"/>
            </svg>
        </button>
        <button class="t3d-tool @(State.ShowOriginDot ? "active" : "")" @onclick="OnToggleOriginDot" title="@State.T("Afficher l'origine")">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <line x1="12" y1="2" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="22"/>
                <line x1="2" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="22" y2="12"/>
            </svg>
        </button>
        @if (State.ImportMode == "2D")
        {
            <div class="t3d-sep"></div>
            <button class="t3d-tool @(State.GridOverlay ? "active" : "")" @onclick="OnToggleGridOverlay" title="Grid">G</button>
        }
        <div class="t3d-sep"></div>
        <button class="t3d-tool @(!State.ImportVisible ? "inactive" : "")"
                @onclick="OnToggleImportVisible" title="@(State.ImportVisible ? State.T("Cacher") : State.T("Afficher"))">
            @if (State.ImportVisible)
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
            }
            else
            {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
            }
        </button>
    </div>
}

@code {
    protected override void OnInitialized() => State.OnStateChanged += StateHasChanged;
    public void Dispose() => State.OnStateChanged -= StateHasChanged;

    private async Task SetTool(string tool) { await State.SetT3DTool(tool); State.NotifyStateChanged(); }
    private async Task OnToggleOriginDot() { await State.ToggleOriginDot(); State.NotifyStateChanged(); }
    private async Task OnToggleGridOverlay() { await State.ToggleGridOverlay(); State.NotifyStateChanged(); }
    private async Task OnToggleImportVisible() { await State.ToggleImportVisible(); State.NotifyStateChanged(); }
}
