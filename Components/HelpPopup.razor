@implements IDisposable
@inject AppState State

@if (State.ShowHelp)
{
    <div class="help-overlay" @onclick="Toggle">
        <div class="help-popup help-popup-wide" @onclick:stopPropagation>
            <div class="help-popup-header">
                <span>@State.T("Aide")</span>
                <button class="help-close-btn" @onclick="Toggle">✕</button>
            </div>
            <div class="help-tab-bar">
                <button class="help-tab-btn @(_tab==0?"active":"")" @onclick="()=>_tab=0">@State.T("Présentation")</button>
                <button class="help-tab-btn @(_tab==1?"active":"")" @onclick="()=>_tab=1">Animation</button>
                <button class="help-tab-btn @(_tab==2?"active":"")" @onclick="()=>_tab=2">@State.T("Comment ça marche ?")</button>
                <button class="help-tab-btn @(_tab==3?"active":"")" @onclick="()=>_tab=3">Export</button>
                <button class="help-tab-btn @(_tab==4?"active":"")" @onclick="()=>_tab=4">@State.T("Icônes")</button>
            </div>
            <div class="help-tab-body">

                @* ── Présentation ──────────────────────────────────────────── *@
                @if (_tab == 0)
                {
                    <div class="help-h2">@L("Pourquoi utiliser ce site ?", "Why use this tool?")</div>
                    <p class="help-p">@L(
                        "Dans TrackMania Nations Forever, créer des formes personnalisées dans le MediaTracker oblige à entrer chaque sommet un par un avec des coordonnées XYZ — ce qui prendrait une éternité pour n'importe quelle forme complexe.",
                        "In TrackMania Nations Forever, creating custom shapes in MediaTracker requires entering every vertex one by one with XYZ coordinates — which takes forever for any complex shape."
                    )</p>
                    <p class="help-p">@L(
                        "Ce site permet d'importer des modèles 3D au format .obj/.mtl et de les convertir automatiquement en données prêtes à être animées dans le MediaTracker.",
                        "This tool lets you import 3D models in .obj/.mtl format and automatically convert them into data ready to animate in MediaTracker."
                    )</p>
                    <div class="help-h2">@L("Limitations", "Limitations")</div>
                    <div class="help-warn">
                        <ul style="margin:0;padding-left:16px">
                            <li style="margin-bottom:4px">@L(
                                "Triangles3D/2D fonctionne uniquement avec des couleurs RGB — aucune texture n'est supportée.",
                                "Triangles3D/2D only supports RGB colors — no textures are supported."
                            )</li>
                            <li style="margin-bottom:4px">@L(
                                "Pas de collision : les voitures et joueurs traversent le modèle.",
                                "No collision: cars and players pass through the model."
                            )</li>
                            <li>@L("Aucune ombre n'est générée.", "No shadows are generated.")</li>
                        </ul>
                    </div>
                }

                @* ── Animation ─────────────────────────────────────────────── *@
                else if (_tab == 1)
                {
                    foreach (var (name, fr, en) in _animItems)
                    {
                        <div class="help-anim-row">
                            <span class="help-anim-name">@name</span>
                            <span class="help-anim-desc">@L(fr, en)</span>
                        </div>
                    }
                }

                @* ── Comment ça marche ? ───────────────────────────────────── *@
                else if (_tab == 2)
                {
                    int stepN = 1;
                    foreach (var (fr, en) in _steps)
                    {
                        int n = stepN++;
                        <div class="help-step">
                            <span class="help-step-num">@n</span>
                            <span>@L(fr, en)</span>
                        </div>
                    }
                }

                @* ── Export ────────────────────────────────────────────────── *@
                else if (_tab == 3)
                {
                    foreach (var (tag, fr, en) in _exports)
                    {
                        <div class="help-export-row">
                            <span class="help-export-tag">@tag</span>
                            <span class="help-p" style="margin:0">@L(fr, en)</span>
                        </div>
                    }
                }

                @* ── Icônes ────────────────────────────────────────────────── *@
                else if (_tab == 4)
                {
                    foreach (var (svg, nameFR, nameEN, descFR, descEN) in _icons)
                    {
                        <div class="help-icon-row">
                            <div class="help-icon-cell">@((MarkupString)svg)</div>
                            <div class="help-icon-info">
                                <div class="help-icon-name">@L(nameFR, nameEN)</div>
                                <div class="help-icon-desc">@L(descFR, descEN)</div>
                            </div>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
}

